PORT=3000
MONGO_URI=mongodb://localhost:27017/geosound
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d
NODE_ENV=development

# ── Linode Object Storage ──────────────────────────────────────────────────────
# Leave these variables empty (or remove them) to use local disk storage instead.
#
# How to get these values:
#   1. Log in to https://cloud.linode.com
#   2. Go to Object Storage → Access Keys → Create Access Key
#      → copy the Access Key ID  →  LINODE_STORAGE_ACCESS_KEY
#      → copy the Secret Key     →  LINODE_STORAGE_SECRET_KEY
#   3. Go to Object Storage → Buckets → Create Bucket
#      → choose a cluster (e.g. us-east-1, eu-central, ap-south)
#      → copy the bucket label   →  LINODE_STORAGE_BUCKET
#      → copy the cluster ID     →  LINODE_STORAGE_CLUSTER  &  LINODE_STORAGE_REGION
#
# Endpoint pattern: https://<LINODE_STORAGE_CLUSTER>.linodeobjects.com
# Public file URL : https://<LINODE_STORAGE_BUCKET>.<LINODE_STORAGE_CLUSTER>.linodeobjects.com/<key>
#
LINODE_STORAGE_ACCESS_KEY=your_linode_access_key_id
LINODE_STORAGE_SECRET_KEY=your_linode_secret_access_key
LINODE_STORAGE_BUCKET=your_bucket_name
LINODE_STORAGE_CLUSTER=us-east-1
LINODE_STORAGE_REGION=us-east-1
