PORT=3000
MONGO_URI=mongodb://localhost:27017/geosound
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d
NODE_ENV=development

# ── Linode Object Storage ──────────────────────────────────────────────────────
# Leave all four variables empty (or remove them) to use local disk storage.
#
# IMPORTANT: you need Object Storage Access Keys, NOT your Linode API token.
#
# Step-by-step setup:
#   1. Log in to https://cloud.linode.com
#   2. Go to Object Storage → Access Keys → Create Access Key
#        Label: anything (e.g. "geosound")
#        Bucket Access: Limited → select your bucket → Read/Write
#        → Save the "Access Key"  →  LINODE_STORAGE_ACCESS_KEY
#        → Save the "Secret Key"  →  LINODE_STORAGE_SECRET_KEY
#          (the Secret Key is only shown once – copy it immediately)
#   3. Go to Object Storage → Buckets → Create Bucket
#        → Enter a bucket label    →  LINODE_STORAGE_BUCKET
#        → Choose a cluster region →  LINODE_STORAGE_CLUSTER
#
# Available Linode cluster IDs for LINODE_STORAGE_CLUSTER:
#   us-east-1        Newark, NJ (USA)
#   us-southeast-1   Atlanta, GA (USA)
#   eu-central-1     Frankfurt, Germany
#   ap-south-1       Singapore
#   ap-west-1        Mumbai, India
#   ap-southeast-1   Sydney, Australia
#   us-ord-1         Chicago, IL (USA)
#   fr-par-1         Paris, France
#   id-cgk-1         Jakarta, Indonesia
#   br-gru-1         São Paulo, Brazil
#   es-mad-1         Madrid, Spain
#   it-mil-1         Milan, Italy
#   jp-osa-1         Osaka, Japan
#   nl-ams-1         Amsterdam, Netherlands
#   se-sto-1         Stockholm, Sweden
#   in-maa-1         Chennai, India
#   gb-lon-1         London, UK
#
# Endpoint: https://<LINODE_STORAGE_CLUSTER>.linodeobjects.com
# Public file URL: https://<LINODE_STORAGE_BUCKET>.<LINODE_STORAGE_CLUSTER>.linodeobjects.com/<key>
#
LINODE_STORAGE_ACCESS_KEY=your_object_storage_access_key
LINODE_STORAGE_SECRET_KEY=your_object_storage_secret_key
LINODE_STORAGE_BUCKET=your_bucket_name
LINODE_STORAGE_CLUSTER=eu-central-1
