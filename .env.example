PORT=3000
MONGO_URI=mongodb://localhost:27017/geosound
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d
NODE_ENV=development

# ── Amazon S3 ──────────────────────────────────────────────────────────────────
# Leave all four variables empty (or remove them) to use local disk storage.
#
# IMPORTANT: you need IAM Access Keys, NOT your AWS root account credentials.
#
# Step-by-step setup:
#   1. Log in to https://console.aws.amazon.com
#
#   2. Create an S3 bucket:
#        Go to S3 → Create bucket
#        → Enter a bucket name (e.g. "geo-sound")    →  AWS_S3_BUCKET
#        → Choose an AWS region (e.g. eu-central-1)  →  AWS_S3_REGION
#        → Leave "Block all public access" checked (default)
#        → Click "Create bucket"
#
#   3. Create an IAM user with S3 access:
#        Go to IAM → Users → Create user
#        → Enter a username (e.g. "geosound-s3")
#        → Attach permissions directly
#          Recommended (least privilege): create a custom inline policy:
#            {
#              "Effect": "Allow",
#              "Action": ["s3:PutObject","s3:GetObject","s3:DeleteObject"],
#              "Resource": "arn:aws:s3:::your-bucket-name/*"
#            }
#          Simple alternative: attach the managed policy "AmazonS3FullAccess"
#          (grants access to ALL buckets in your account – fine for personal projects)
#        → Click "Create user"
#
#   4. Generate access keys for the IAM user:
#        Click the user you just created → Security credentials tab
#        → Create access key
#        → Use case: "Application running outside AWS"
#        → Save the "Access key ID"   →  AWS_S3_ACCESS_KEY
#        → Save the "Secret access key" →  AWS_S3_SECRET_KEY
#          (the Secret key is only shown once – copy it immediately)
#
# Available AWS regions for AWS_S3_REGION (choose the one closest to your users):
#   us-east-1        N. Virginia, USA
#   us-east-2        Ohio, USA
#   us-west-1        N. California, USA
#   us-west-2        Oregon, USA
#   eu-central-1     Frankfurt, Germany
#   eu-west-1        Ireland
#   eu-west-2        London, UK
#   eu-west-3        Paris, France
#   eu-north-1       Stockholm, Sweden
#   eu-south-1       Milan, Italy
#   ap-east-1        Hong Kong
#   ap-south-1       Mumbai, India
#   ap-southeast-1   Singapore
#   ap-southeast-2   Sydney, Australia
#   ap-northeast-1   Tokyo, Japan
#   ap-northeast-2   Seoul, South Korea
#   ca-central-1     Canada (Central)
#   sa-east-1        São Paulo, Brazil
#   me-south-1       Bahrain
#   af-south-1       Cape Town, South Africa
#
# Audio files are stored as private objects and served via pre-signed URLs
# (valid for 24 hours), so there is no need to make the bucket public.
#
AWS_S3_ACCESS_KEY=your_iam_access_key_id
AWS_S3_SECRET_KEY=your_iam_secret_access_key
AWS_S3_BUCKET=your_bucket_name
AWS_S3_REGION=eu-central-1

