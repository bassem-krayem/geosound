<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<main id="main-content">
  <div class="container">

    <div class="page-header">
      <div>
        <h1>Teacher Dashboard</h1>
        <p class="text-muted">Welcome, <strong><%= user.name %></strong></p>
      </div>
      <a href="/teacher/courses/new" class="btn btn-primary">+ New Course</a>
    </div>

    <%- include('../partials/flash') %>

    <!-- Stats -->
    <div class="stat-cards mb-4" aria-label="Teaching statistics">
      <div class="stat-card">
        <div class="stat-number"><%= stats.courses %></div>
        <div class="stat-label">Courses</div>
      </div>
      <div class="stat-card">
        <div class="stat-number"><%= stats.modules %></div>
        <div class="stat-label">Modules</div>
      </div>
      <div class="stat-card">
        <div class="stat-number"><%= stats.lessons %></div>
        <div class="stat-label">Lessons</div>
      </div>
      <div class="stat-card">
        <div class="stat-number"><%= stats.quizzes %></div>
        <div class="stat-label">Quizzes</div>
      </div>
    </div>

    <h2 class="mb-3">Your Courses</h2>

    <% if (courses.length === 0) { %>
      <div class="alert alert-info">
        You haven't created any courses yet. <a href="/teacher/courses/new">Create your first course</a>!
      </div>
    <% } else { %>
      <div class="grid grid-2">
        <% courses.forEach(course => { %>
          <article class="course-card">
            <div class="course-card-body">
              <h3><%= course.title %></h3>
              <p><%= course.description || 'No description.' %></p>
            </div>
            <div class="course-card-footer">
              <a href="/teacher/courses/<%= course._id %>" class="btn btn-primary btn-sm">Manage</a>
              <a href="/teacher/courses/<%= course._id %>/edit" class="btn btn-secondary btn-sm">Edit</a>
              <form action="/teacher/courses/<%= course._id %>/delete" method="POST" style="margin:0">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <button
                  type="submit"
                  class="btn btn-danger btn-sm"
                  data-confirm="Delete course '<%= course.title %>' and all its content? This cannot be undone."
                >Delete</button>
              </form>
            </div>
          </article>
        <% }) %>
      </div>
    <% } %>

  </div>
</main>

<%- include('../partials/footer') %>
