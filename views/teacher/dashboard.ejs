<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<main id="main-content">
  <div class="container">

    <div class="page-header">
      <div>
        <h1>لوحة تحكم المعلم</h1>
        <p class="text-muted">مرحباً، <strong><%= user.name %></strong></p>
      </div>
      <a href="/teacher/levels/new" class="btn btn-primary">+ مستوى جديد</a>
    </div>

    <%- include('../partials/flash') %>

    <!-- إحصاءات -->
    <div class="stat-cards mb-4" aria-label="إحصاءات التدريس">
      <div class="stat-card">
        <div class="stat-number"><%= stats.courses %></div>
        <div class="stat-label">المستويات</div>
      </div>
      <div class="stat-card">
        <div class="stat-number"><%= stats.modules %></div>
        <div class="stat-label">الوحدات</div>
      </div>
      <div class="stat-card">
        <div class="stat-number"><%= stats.lessons %></div>
        <div class="stat-label">الدروس</div>
      </div>
      <div class="stat-card">
        <div class="stat-number"><%= stats.quizzes %></div>
        <div class="stat-label">الاختبارات</div>
      </div>
    </div>

    <h2 class="mb-3">مستوياتك</h2>

    <% if (courses.length === 0) { %>
      <div class="alert alert-info">
        لم تنشئ أي مستويات بعد. <a href="/teacher/levels/new">أنشئ أول مستوى لك</a>!
      </div>
    <% } else { %>
      <div class="grid grid-2">
        <% courses.forEach(course => { %>
          <article class="course-card">
            <div class="course-card-body">
              <h3><%= course.title %></h3>
              <p><%= course.description || 'لا يوجد وصف.' %></p>
            </div>
            <div class="course-card-footer">
              <a href="/teacher/levels/<%= course._id %>" class="btn btn-primary btn-sm">إدارة</a>
              <a href="/teacher/levels/<%= course._id %>/edit" class="btn btn-secondary btn-sm">تعديل</a>
              <form action="/teacher/levels/<%= course._id %>/delete" method="POST" style="margin:0">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <button
                  type="submit"
                  class="btn btn-danger btn-sm"
                  data-confirm="حذف المستوى '<%= course.title %>' وكل محتواه؟ لا يمكن التراجع عن هذا."
                >حذف</button>
              </form>
            </div>
          </article>
        <% }) %>
      </div>
    <% } %>

  </div>
</main>

<%- include('../partials/footer') %>
