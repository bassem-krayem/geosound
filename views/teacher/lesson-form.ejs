<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<main id="main-content">
  <div class="container">
    <div class="form-page">

      <%- include('../partials/flash') %>

      <!-- Breadcrumb -->
      <ol class="breadcrumb" aria-label="Breadcrumb">
        <li><a href="/teacher/dashboard">Dashboard</a></li>
        <li><a href="/teacher/courses/<%= courseId %>"><%= courseTitle %></a></li>
        <li><%= isEdit ? 'Edit Lesson' : 'New Lesson' %></li>
      </ol>

      <h1 class="mb-3"><%= isEdit ? 'Edit Lesson' : 'Add Lesson' %></h1>

      <div class="card">
        <div class="card-body">
          <form
            action="<%= isEdit ? '/teacher/courses/' + courseId + '/modules/' + moduleId + '/lessons/' + lesson._id + '/edit' : '/teacher/courses/' + courseId + '/modules/' + moduleId + '/lessons/new' %>"
            method="POST"
            enctype="multipart/form-data"
            novalidate
            aria-label="<%= isEdit ? 'Edit lesson form' : 'Create lesson form' %>"
          >
            <%- include('../partials/csrf') %>
            <div class="form-group">
              <label class="form-label" for="title">Lesson Title <span aria-hidden="true" class="text-danger">*</span></label>
              <input
                class="form-control"
                type="text"
                id="title"
                name="title"
                required
                aria-required="true"
                value="<%= typeof lesson !== 'undefined' && lesson.title ? lesson.title : '' %>"
              />
            </div>

            <div class="form-group">
              <label class="form-label" for="description">Description</label>
              <textarea class="form-control" id="description" name="description"><%= typeof lesson !== 'undefined' && lesson.description ? lesson.description : '' %></textarea>
            </div>

            <div class="form-group">
              <label class="form-label" for="audio">Audio File <span class="text-muted" style="font-weight:400">(MP3, WAV, OGG, AAC – max 50 MB)</span></label>
              <input
                class="form-control"
                type="file"
                id="audio"
                name="audio"
                accept="audio/*"
                aria-describedby="audio-hint"
              />
              <% if (isEdit && lesson && lesson.audioUrl) { %>
                <p class="form-hint" id="audio-hint">
                  Current audio: <a href="<%= lesson.audioUrl %>" target="_blank">Listen</a>.
                  Upload a new file to replace it.
                </p>
              <% } else { %>
                <span class="form-hint" id="audio-hint">Upload the audio recording for this lesson.</span>
              <% } %>
            </div>

            <div class="form-group">
              <label class="form-label" for="order">Display Order</label>
              <input
                class="form-control"
                type="number"
                id="order"
                name="order"
                min="0"
                value="<%= typeof lesson !== 'undefined' && lesson.order !== undefined ? lesson.order : 0 %>"
                style="max-width:120px"
              />
            </div>

            <div class="d-flex gap-2 flex-wrap">
              <button type="submit" class="btn btn-primary"><%= isEdit ? 'Save Changes' : 'Add Lesson' %></button>
              <a href="/teacher/courses/<%= courseId %>" class="btn btn-secondary">Cancel</a>
            </div>
          </form>
        </div>
      </div>

    </div>
  </div>
</main>

<%- include('../partials/footer') %>
