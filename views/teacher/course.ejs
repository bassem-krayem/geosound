<%- include('../partials/head') %>
  <%- include('../partials/navbar') %>

    <main id="main-content">
      <div class="container">

        <%- include('../partials/flash') %>

          <ol class="breadcrumb" aria-label="مسار التنقل">
            <li><a href="/teacher/dashboard">لوحة التحكم</a></li>
            <li>
              <%= course.title %>
            </li>
          </ol>

          <div class="page-header">
            <div>
              <h1>
                <%= course.title %>
              </h1>
              <% if (course.description) { %>
                <p class="text-muted">
                  <%= course.description %>
                </p>
                <% } %>
            </div>
            <div class="d-flex gap-1 flex-wrap">
              <a href="/teacher/levels/<%= course._id %>/edit" class="btn btn-secondary btn-sm">تعديل المستوى</a>
              <a href="/teacher/levels/<%= course._id %>/modules/new" class="btn btn-primary">+ إضافة وحدة</a>
            </div>
          </div>

          <% if (!modules || modules.length===0) { %>
            <div class="alert alert-info">لا توجد وحدات بعد. <a href="/teacher/levels/<%= course._id %>/modules/new">أضف
                أول وحدة</a>.</div>
            <% } else { %>
              <% modules.forEach((mod, mIdx)=> { %>
                <div class="module-block"
                  style="border: 1px solid #ddd; border-radius: 8px; margin-bottom: 1rem; overflow: hidden;">

                  <div class="module-header-wrapper"
                    style="display: flex; align-items: center; justify-content: space-between; background: #f9f9f9; border-bottom: 1px solid #eee; padding: 0.5rem 1rem;">

                    <button class="module-header-toggle"
                      style="flex-grow: 1; text-align: right; background: none; border: none; cursor: pointer; padding: 0.5rem 0;"
                      aria-expanded="true" aria-controls="mod-body-<%= mod._id %>" type="button">
                      <h3 style="margin:0">الوحدة <%= mIdx + 1 %>: <%= mod.title %>
                      </h3>
                      <% if (mod.description) { %>
                        <p style="font-size:.85rem; color:var(--text-muted); margin:0">
                          <%= mod.description %>
                        </p>
                        <% } %>
                    </button>

                    <div class="module-actions d-flex gap-1 align-center flex-wrap"
                      style="flex-shrink:0; margin-right: 1rem;">
                      <a href="/teacher/levels/<%= course._id %>/modules/<%= mod._id %>/lessons/new"
                        class="btn btn-primary btn-sm">+ درس</a>
                      <a href="/teacher/levels/<%= course._id %>/modules/<%= mod._id %>/edit"
                        class="btn btn-secondary btn-sm">تعديل</a>

                      <form action="/teacher/levels/<%= course._id %>/modules/<%= mod._id %>/delete" method="POST"
                        style="margin:0">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                        <button type="submit" class="btn btn-danger btn-sm"
                          data-confirm="حذف الوحدة '<%= mod.title %>' وجميع دروسها؟">حذف</button>
                      </form>
                      <span class="chevron" aria-hidden="true"
                        style="margin-right:.25rem; pointer-events: none;">▼</span>
                    </div>
                  </div>

                  <div id="mod-body-<%= mod._id %>">
                    <% if (!mod.lessons || mod.lessons.length===0) { %>
                      <p style="padding:.85rem 1.25rem;color:var(--text-muted);font-size:.9rem">لا توجد دروس بعد. <a
                          href="/teacher/levels/<%= course._id %>/modules/<%= mod._id %>/lessons/new">أضف درساً</a>.</p>
                      <% } else { %>
                        <ul class="lesson-list" aria-label="دروس <%= mod.title %>"
                          style="list-style: none; padding: 0; margin: 0;">
                          <% mod.lessons.forEach((lesson, lIdx)=> { %>
                            <li class="lesson-item"
                              style="display: flex; align-items: center; justify-content: space-between; padding: 1rem; border-bottom: 1px solid #eee;">
                              <div style="display: flex; align-items: center; gap: 1rem;">
                                <span class="lesson-icon" aria-hidden="true" style="font-size: 1.5rem;">
                                  <%= lesson.audioUrl ? '🎧' : '📄' %>
                                </span>
                                <div class="lesson-info">
                                  <h4 style="margin:0">
                                    <%= lesson.title %>
                                  </h4>
                                  <p style="margin:0; font-size: 0.8rem; color: #666;">
                                    <%= lesson.audioUrl ? '✓ تم رفع الصوت' : '⚠ لا يوجد صوت' %>
                                  </p>
                                </div>
                              </div>
                              <div class="d-flex gap-1 flex-wrap">
                                <a href="/teacher/levels/<%= course._id %>/modules/<%= mod._id %>/lessons/<%= lesson._id %>/quiz"
                                  class="btn btn-accent btn-sm">اختبار</a>
                                <a href="/teacher/levels/<%= course._id %>/modules/<%= mod._id %>/lessons/<%= lesson._id %>/edit"
                                  class="btn btn-secondary btn-sm">تعديل</a>
                                <form
                                  action="/teacher/levels/<%= course._id %>/modules/<%= mod._id %>/lessons/<%= lesson._id %>/delete"
                                  method="POST" style="margin:0">
                                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                                  <button type="submit" class="btn btn-danger btn-sm"
                                    data-confirm="حذف الدرس '<%= lesson.title %>'؟">حذف</button>
                                </form>
                              </div>
                            </li>
                            <% }) %>
                        </ul>
                        <% } %>
                  </div>
                </div>
                <% }) %>
                  <% } %>

      </div>
    </main>

    <%- include('../partials/footer') %>