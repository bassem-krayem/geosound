<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<main id="main-content">
  <div class="container">
    <div class="form-page">

      <%- include('../partials/flash') %>

      <!-- مسار التنقل -->
      <ol class="breadcrumb" aria-label="مسار التنقل">
        <li><a href="/teacher/dashboard">لوحة التحكم</a></li>
        <li><a href="/teacher/courses/<%= courseId %>"><%= courseTitle %></a></li>
        <li><%= isEdit ? 'تعديل الوحدة' : 'وحدة جديدة' %></li>
      </ol>

      <h1 class="mb-3"><%= isEdit ? 'تعديل الوحدة' : 'إضافة وحدة' %></h1>

      <div class="card">
        <div class="card-body">
          <form
            action="<%= isEdit ? '/teacher/courses/' + courseId + '/modules/' + module._id + '/edit' : '/teacher/courses/' + courseId + '/modules/new' %>"
            method="POST"
            novalidate
            aria-label="<%= isEdit ? 'نموذج تعديل الوحدة' : 'نموذج إضافة الوحدة' %>"
          >
            <%- include('../partials/csrf') %>
            <div class="form-group">
              <label class="form-label" for="title">عنوان الوحدة <span aria-hidden="true" class="text-danger">*</span></label>
              <input
                class="form-control"
                type="text"
                id="title"
                name="title"
                required
                aria-required="true"
                value="<%= typeof module !== 'undefined' && module.title ? module.title : '' %>"
              />
            </div>

            <div class="form-group">
              <label class="form-label" for="description">الوصف</label>
              <textarea
                class="form-control"
                id="description"
                name="description"
              ><%= typeof module !== 'undefined' && module.description ? module.description : '' %></textarea>
            </div>

            <div class="form-group">
              <label class="form-label" for="order">ترتيب العرض</label>
              <input
                class="form-control"
                type="number"
                id="order"
                name="order"
                min="0"
                value="<%= typeof module !== 'undefined' && module.order !== undefined ? module.order : 0 %>"
                style="max-width:120px"
              />
              <span class="form-hint">الأرقام الأصغر تظهر أولاً.</span>
            </div>

            <div class="d-flex gap-2 flex-wrap">
              <button type="submit" class="btn btn-primary"><%= isEdit ? 'حفظ التغييرات' : 'إضافة الوحدة' %></button>
              <a href="/teacher/courses/<%= courseId %>" class="btn btn-secondary">إلغاء</a>
            </div>
          </form>
        </div>
      </div>

    </div>
  </div>
</main>

<%- include('../partials/footer') %>
