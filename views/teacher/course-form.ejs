<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<main id="main-content">
  <div class="container">
    <div class="form-page">

      <%- include('../partials/flash') %>

      <!-- مسار التنقل -->
      <ol class="breadcrumb" aria-label="مسار التنقل">
        <li><a href="/teacher/dashboard">لوحة التحكم</a></li>
        <li><%= isEdit ? 'تعديل المستوى' : 'مستوى جديد' %></li>
      </ol>

      <h1 class="mb-3"><%= isEdit ? 'تعديل المستوى' : 'إنشاء مستوى جديد' %></h1>

      <div class="card">
        <div class="card-body">
          <form
            action="<%= isEdit ? '/teacher/levels/' + course._id + '/edit' : '/teacher/levels/new' %>"
            method="POST"
            novalidate
            aria-label="<%= isEdit ? 'نموذج تعديل المستوى' : 'نموذج إنشاء المستوى' %>"
          >
            <%- include('../partials/csrf') %>
            <div class="form-group">
              <label class="form-label" for="title">عنوان المستوى <span aria-hidden="true" class="text-danger">*</span></label>
              <select class="form-control" id="title" name="title" required aria-required="true">
                <option value="" disabled <%= typeof course === 'undefined' || !course.title ? 'selected' : '' %>>اختر المستوى</option>
                <option value="السنة الخامسة من التعليم الأساسي" <%= typeof course !== 'undefined' && course.title === 'السنة الخامسة من التعليم الأساسي' ? 'selected' : '' %>>السنة الخامسة من التعليم الأساسي</option>
                <option value="السنة السادسة من التعليم الأساسي" <%= typeof course !== 'undefined' && course.title === 'السنة السادسة من التعليم الأساسي' ? 'selected' : '' %>>السنة السادسة من التعليم الأساسي</option>
              </select>
            </div>

            <div class="form-group">
              <label class="form-label" for="description">الوصف</label>
              <textarea
                class="form-control"
                id="description"
                name="description"
              ><%= typeof course !== 'undefined' && course.description ? course.description : '' %></textarea>
            </div>

            <div class="d-flex gap-2 flex-wrap">
              <button type="submit" class="btn btn-primary"><%= isEdit ? 'حفظ التغييرات' : 'إنشاء المستوى' %></button>
              <a href="/teacher/dashboard" class="btn btn-secondary">إلغاء</a>
            </div>
          </form>
        </div>
      </div>

    </div>
  </div>
</main>

<%- include('../partials/footer') %>
