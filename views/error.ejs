<%- include('partials/head') %>
<%- include('partials/navbar') %>

<main id="main-content">
  <div class="container" style="max-width:640px;margin-top:4rem;text-align:center">
    <div style="font-size:4rem;margin-bottom:1rem" aria-hidden="true"><%= statusCode === 404 ? '🔍' : '⚠️' %></div>
    <h1><%= statusCode %> – <%= message %></h1>
    <p class="text-muted mt-2">Sorry, something went wrong. Please try again or return home.</p>
    <a href="/" class="btn btn-primary mt-3">Go Home</a>
  </div>
</main>

<%- include('partials/footer') %>
