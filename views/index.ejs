<%- include('partials/head') %>
<%- include('partials/navbar') %>

<main id="main-content">
  <!-- Hero -->
  <section class="hero" aria-labelledby="hero-heading">
    <div class="container">
      <h1 id="hero-heading">Learn Geography Through Sound</h1>
      <p>An accessible, audio-first platform designed for blind and visually impaired students. Listen to lessons, take quizzes, and unlock new knowledge one step at a time.</p>
      <div>
        <a href="/register" class="btn btn-accent btn-lg">Get Started Free</a>
        <a href="/courses" class="btn btn-secondary btn-lg" style="margin-left:.75rem; border-color:rgba(255,255,255,.5); color:#fff;">Browse Courses</a>
      </div>
      <div class="hero-badges" aria-label="Platform features">
        <span class="badge">🎧 Audio Lessons</span>
        <span class="badge">📝 Interactive Quizzes</span>
        <span class="badge">🔓 Progress-Based Unlocking</span>
        <span class="badge">♿ Accessibility First</span>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="features" aria-labelledby="features-heading">
    <div class="container">
      <h2 id="features-heading" class="text-center mb-4">How It Works</h2>
      <div class="grid grid-3">
        <article class="feature-card">
          <div class="feature-icon" aria-hidden="true">🎓</div>
          <h3>Enroll &amp; Learn</h3>
          <p>Browse courses created by expert geography teachers, enroll in seconds, and start with the first audio lesson immediately.</p>
        </article>
        <article class="feature-card">
          <div class="feature-icon" aria-hidden="true">🎧</div>
          <h3>Listen Carefully</h3>
          <p>Every lesson contains a high-quality audio recording. Use headphones for the best experience. Replay as many times as you need.</p>
        </article>
        <article class="feature-card">
          <div class="feature-icon" aria-hidden="true">✅</div>
          <h3>Pass to Progress</h3>
          <p>After each lesson, answer 5 quiz questions. Score at least 70% to unlock the next lesson. Retry as many times as you need.</p>
        </article>
      </div>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
