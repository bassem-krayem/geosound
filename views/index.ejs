<%- include('partials/head') %>
<%- include('partials/navbar') %>

<main id="main-content">
  <!-- Hero -->
  <section class="hero" aria-labelledby="hero-heading">
    <div class="container">
      <h1 id="hero-heading">تعلّم الجغرافيا من خلال الصوت</h1>
      <p>منصة صوتية أولى مصمّمة للطلاب المكفوفين وضعاف البصر. استمع إلى الدروس، أجب على الاختبارات، وافتح معرفة جديدة خطوة بخطوة.</p>
      <div>
        <a href="/register" class="btn btn-accent btn-lg">ابدأ مجاناً</a>
        <a href="/courses" class="btn btn-secondary btn-lg" style="margin-right:.75rem; border-color:rgba(255,255,255,.5); color:#fff;">استعرض الدورات</a>
      </div>
      <div class="hero-badges" aria-label="مميزات المنصة">
        <span class="badge">🎧 دروس صوتية</span>
        <span class="badge">📝 اختبارات تفاعلية</span>
        <span class="badge">🔓 فتح قائم على التقدم</span>
        <span class="badge">♿ إمكانية الوصول أولاً</span>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="features" aria-labelledby="features-heading">
    <div class="container">
      <h2 id="features-heading" class="text-center mb-4">كيف يعمل؟</h2>
      <div class="grid grid-3">
        <article class="feature-card">
          <div class="feature-icon" aria-hidden="true">🎓</div>
          <h3>سجّل وتعلّم</h3>
          <p>تصفّح الدورات التي أنشأها معلمو الجغرافيا الخبراء، سجّل خلال ثوانٍ، وابدأ بالدرس الصوتي الأول فوراً.</p>
        </article>
        <article class="feature-card">
          <div class="feature-icon" aria-hidden="true">🎧</div>
          <h3>استمع بعناية</h3>
          <p>كل درس يحتوي على تسجيل صوتي عالي الجودة. استخدم سماعات الأذن للحصول على أفضل تجربة. أعد التشغيل كما تشاء.</p>
        </article>
        <article class="feature-card">
          <div class="feature-icon" aria-hidden="true">✅</div>
          <h3>اجتز لتتقدم</h3>
          <p>بعد كل درس، أجب على 5 أسئلة. احصل على 70% على الأقل لفتح الدرس التالي. أعد المحاولة كما تشاء.</p>
        </article>
      </div>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
