<%- include('../partials/head') %>

<main id="main-content" class="auth-wrapper">
  <div class="auth-card">
    <div class="auth-logo">
      <h1>🌍 GeoSound</h1>
      <p>Welcome back! Please sign in to continue.</p>
    </div>

    <%- include('../partials/flash') %>

    <form action="/login" method="POST" novalidate aria-label="Login form">
      <%- include('../partials/csrf') %>
      <div class="form-group">
        <label class="form-label" for="email">Email address</label>
        <input
          class="form-control"
          type="email"
          id="email"
          name="email"
          autocomplete="email"
          required
          aria-required="true"
          value="<%= typeof formData !== 'undefined' && formData.email ? formData.email : '' %>"
        />
      </div>

      <div class="form-group">
        <label class="form-label" for="password">Password</label>
        <input
          class="form-control"
          type="password"
          id="password"
          name="password"
          autocomplete="current-password"
          required
          aria-required="true"
        />
      </div>

      <button type="submit" class="btn btn-primary btn-block btn-lg">Sign In</button>
    </form>

    <p class="auth-divider">Don't have an account? <a href="/register">Register here</a></p>
  </div>
</main>

<%- include('../partials/footer') %>
