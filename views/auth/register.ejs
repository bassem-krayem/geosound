<%- include('../partials/head') %>

<main id="main-content" class="auth-wrapper">
  <div class="auth-card">
    <div class="auth-logo">
      <h1>🌍 GeoSound</h1>
      <p>Create your account to start learning.</p>
    </div>

    <%- include('../partials/flash') %>

    <form action="/register" method="POST" novalidate aria-label="Registration form">
      <%- include('../partials/csrf') %>
      <div class="form-group">
        <label class="form-label" for="name">Full name</label>
        <input
          class="form-control"
          type="text"
          id="name"
          name="name"
          autocomplete="name"
          required
          aria-required="true"
          value="<%= typeof formData !== 'undefined' && formData.name ? formData.name : '' %>"
        />
      </div>

      <div class="form-group">
        <label class="form-label" for="email">Email address</label>
        <input
          class="form-control"
          type="email"
          id="email"
          name="email"
          autocomplete="email"
          required
          aria-required="true"
          value="<%= typeof formData !== 'undefined' && formData.email ? formData.email : '' %>"
        />
      </div>

      <div class="form-group">
        <label class="form-label" for="password">Password <span class="text-muted" style="font-weight:400">(min. 6 characters)</span></label>
        <input
          class="form-control"
          type="password"
          id="password"
          name="password"
          autocomplete="new-password"
          required
          aria-required="true"
          minlength="6"
        />
      </div>

      <div class="form-group">
        <label class="form-label" for="role">I am a…</label>
        <select class="form-control" id="role" name="role" required aria-required="true">
          <option value="" disabled <%= typeof formData === 'undefined' || !formData.role ? 'selected' : '' %>>Choose your role</option>
          <option value="student" <%= typeof formData !== 'undefined' && formData.role === 'student' ? 'selected' : '' %>>Student</option>
          <option value="teacher" <%= typeof formData !== 'undefined' && formData.role === 'teacher' ? 'selected' : '' %>>Teacher</option>
        </select>
      </div>

      <button type="submit" class="btn btn-primary btn-block btn-lg">Create Account</button>
    </form>

    <p class="auth-divider">Already have an account? <a href="/login">Sign in here</a></p>
  </div>
</main>

<%- include('../partials/footer') %>
