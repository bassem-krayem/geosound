<%- include('../partials/head') %>

<main id="main-content" class="auth-wrapper">
  <div class="auth-card">
    <div class="auth-logo">
      <h1>🌍 جيوساوند</h1>
      <p>أنشئ حسابك لبدء التعلم.</p>
    </div>

    <%- include('../partials/flash') %>

    <form action="/register" method="POST" novalidate aria-label="نموذج إنشاء الحساب">
      <%- include('../partials/csrf') %>
      <div class="form-group">
        <label class="form-label" for="name">الاسم الكامل</label>
        <input
          class="form-control"
          type="text"
          id="name"
          name="name"
          autocomplete="name"
          required
          aria-required="true"
          value="<%= typeof formData !== 'undefined' && formData.name ? formData.name : '' %>"
        />
      </div>

      <div class="form-group">
        <label class="form-label" for="email">البريد الإلكتروني</label>
        <input
          class="form-control"
          type="email"
          id="email"
          name="email"
          autocomplete="email"
          required
          aria-required="true"
          value="<%= typeof formData !== 'undefined' && formData.email ? formData.email : '' %>"
        />
      </div>

      <div class="form-group">
        <label class="form-label" for="password">كلمة المرور <span class="text-muted" style="font-weight:400">(6 أحرف على الأقل)</span></label>
        <input
          class="form-control"
          type="password"
          id="password"
          name="password"
          autocomplete="new-password"
          required
          aria-required="true"
          minlength="6"
        />
      </div>

      <div class="form-group">
        <label class="form-label" for="role">أنا...</label>
        <select class="form-control" id="role" name="role" required aria-required="true">
          <option value="" disabled <%= typeof formData === 'undefined' || !formData.role ? 'selected' : '' %>>اختر دورك</option>
          <option value="pupil" <%= typeof formData !== 'undefined' && (formData.role === 'pupil' || formData.role === 'student') ? 'selected' : '' %>>تلميذ</option>
          <option value="teacher" <%= typeof formData !== 'undefined' && formData.role === 'teacher' ? 'selected' : '' %>>معلم</option>
        </select>
      </div>

      <button type="submit" class="btn btn-primary btn-block btn-lg">إنشاء حساب</button>
    </form>

    <p class="auth-divider">لديك حساب بالفعل؟ <a href="/login">سجّل الدخول هنا</a></p>
  </div>
</main>

<%- include('../partials/footer') %>
