<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<main id="main-content">
  <div class="container">

    <%- include('../partials/flash') %>

    <!-- Breadcrumb -->
    <ol class="breadcrumb" aria-label="Breadcrumb">
      <li><a href="/courses">Courses</a></li>
      <li><%= course.title %></li>
    </ol>

    <div class="page-header">
      <div>
        <h1><%= course.title %></h1>
        <% if (course.description) { %>
          <p class="text-muted"><%= course.description %></p>
        <% } %>
        <p class="text-muted" style="font-size:.85rem">
          👨‍🏫 Taught by <strong><%= course.teacher ? course.teacher.name : 'Unknown' %></strong>
        </p>
      </div>
      <% if (user && !enrolled) { %>
        <form action="/courses/<%= course._id %>/enroll" method="POST">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <button type="submit" class="btn btn-success">Enroll in Course</button>
        </form>
      <% } else if (user && enrolled) { %>
        <span class="tag tag-unlocked" style="font-size:1rem;padding:.4rem 1rem">✓ Enrolled</span>
      <% } %>
    </div>

    <!-- Progress bar -->
    <% if (user && enrolled && progressData) { %>
      <div class="card mb-3" aria-label="Your progress">
        <div class="card-body">
          <div class="d-flex align-center gap-2 flex-wrap">
            <strong style="flex-shrink:0">Your progress:</strong>
            <div style="flex:1;min-width:120px">
              <div class="progress-bar-wrap">
                <div
                  class="progress-bar-fill <%= progressData.percent === 100 ? 'full' : '' %>"
                  style="width:<%= progressData.percent %>%"
                  role="progressbar"
                  aria-valuenow="<%= progressData.percent %>"
                  aria-valuemin="0"
                  aria-valuemax="100"
                  aria-label="<%= progressData.percent %>% complete"
                ></div>
              </div>
            </div>
            <span><%= progressData.completed %> / <%= progressData.total %> lessons completed</span>
          </div>
        </div>
      </div>
    <% } %>

    <!-- Modules & Lessons -->
    <% if (!modules || modules.length === 0) { %>
      <div class="alert alert-info">This course has no modules yet.</div>
    <% } else { %>
      <% modules.forEach((mod, mIdx) => { %>
        <div class="module-block">
          <button
            class="module-header"
            aria-expanded="true"
            aria-controls="module-body-<%= mod._id %>"
          >
            <h3>
              <span aria-hidden="true" style="font-size:.9rem;opacity:.6">Module <%= mIdx + 1 %></span><br/>
              <%= mod.title %>
            </h3>
            <span class="chevron" aria-hidden="true">▼</span>
          </button>

          <div id="module-body-<%= mod._id %>">
            <% if (!mod.lessons || mod.lessons.length === 0) { %>
              <p style="padding:.85rem 1.25rem;color:var(--text-muted);font-size:.9rem">No lessons in this module yet.</p>
            <% } else { %>
              <ul class="lesson-list" aria-label="<%= mod.title %> lessons">
                <% mod.lessons.forEach((lesson, lIdx) => {
                  const lpData = progressData && progressData.lessons
                    ? progressData.lessons.find(lp => lp.lesson && (lp.lesson._id || lp.lesson).toString() === lesson._id.toString())
                    : null;
                  const isCompleted = lpData && lpData.completed;
                  const isFirst = lIdx === 0;
                  // Determine unlock: first is always open; others need previous completed
                  const prevLesson = lIdx > 0 ? mod.lessons[lIdx - 1] : null;
                  const prevDone = prevLesson
                    ? (progressData && progressData.lessons
                        ? !!(progressData.lessons.find(lp => (lp.lesson._id || lp.lesson).toString() === prevLesson._id.toString()) || {}).completed
                        : false)
                    : true;
                  const isAccessible = enrolled && (isFirst || prevDone);
                %>
                  <li class="lesson-item <%= isCompleted ? 'lesson-complete' : '' %> <%= !isAccessible ? 'lesson-locked' : '' %>">
                    <span class="lesson-icon" aria-hidden="true">
                      <% if (isCompleted) { %>✅
                      <% } else if (!isAccessible) { %>🔒
                      <% } else { %>🎧<% } %>
                    </span>
                    <div class="lesson-info">
                      <h4><%= lesson.title %></h4>
                      <% if (lpData && lpData.score !== null && lpData.score !== undefined) { %>
                        <p>Best score: <strong><%= lpData.score %>%</strong></p>
                      <% } %>
                    </div>
                    <% if (isAccessible) { %>
                      <a
                        href="/courses/<%= course._id %>/modules/<%= mod._id %>/lessons/<%= lesson._id %>"
                        class="btn btn-sm <%= isCompleted ? 'btn-secondary' : 'btn-primary' %>"
                        aria-label="<%= isCompleted ? 'Review' : 'Start' %> lesson: <%= lesson.title %>"
                      ><%= isCompleted ? 'Review' : 'Start' %></a>
                    <% } else { %>
                      <span class="tag tag-locked" aria-label="Locked lesson">🔒 Locked</span>
                    <% } %>
                  </li>
                <% }) %>
              </ul>
            <% } %>
          </div>
        </div>
      <% }) %>
    <% } %>

  </div>
</main>

<%- include('../partials/footer') %>
