<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<main id="main-content">
  <div class="container">

    <div class="page-header">
      <div>
        <h1>My Learning Dashboard</h1>
        <p class="text-muted">Welcome back, <strong><%= user.name %></strong>!</p>
      </div>
      <a href="/courses" class="btn btn-primary">Browse More Courses</a>
    </div>

    <%- include('../partials/flash') %>

    <!-- Stats -->
    <div class="stat-cards mb-4" aria-label="Learning statistics">
      <div class="stat-card">
        <div class="stat-number"><%= enrollments.length %></div>
        <div class="stat-label">Enrolled Courses</div>
      </div>
      <div class="stat-card">
        <div class="stat-number"><%= totalCompleted %></div>
        <div class="stat-label">Lessons Completed</div>
      </div>
    </div>

    <!-- Enrolled courses -->
    <h2 class="mb-3">My Courses</h2>
    <% if (enrollments.length === 0) { %>
      <div class="alert alert-info">
        You haven't enrolled in any courses yet. <a href="/courses">Browse courses</a> to get started!
      </div>
    <% } else { %>
      <div class="grid grid-2">
        <% enrollments.forEach(enr => { %>
          <article class="course-card">
            <div class="course-card-body">
              <h3><%= enr.course ? enr.course.title : 'Course unavailable' %></h3>
              <p><%= enr.course && enr.course.description ? enr.course.description : '' %></p>

              <!-- Progress bar -->
              <% const completed = enr.lessons.filter(l => l.completed).length; %>
              <% const total = enr._totalLessons || 0; %>
              <% const pct = total > 0 ? Math.round((completed / total) * 100) : 0; %>
              <div class="mt-2">
                <div style="display:flex;justify-content:space-between;font-size:.85rem;margin-bottom:.25rem">
                  <span>Progress</span>
                  <span><%= completed %> / <%= total %> lessons</span>
                </div>
                <div class="progress-bar-wrap">
                  <div
                    class="progress-bar-fill <%= pct === 100 ? 'full' : '' %>"
                    style="width:<%= pct %>%"
                    role="progressbar"
                    aria-valuenow="<%= pct %>"
                    aria-valuemin="0"
                    aria-valuemax="100"
                    aria-label="<%= pct %>% complete"
                  ></div>
                </div>
              </div>
            </div>
            <div class="course-card-footer">
              <a href="/courses/<%= enr.course ? enr.course._id : '' %>" class="btn btn-primary btn-sm">
                <%= completed > 0 ? 'Continue' : 'Start' %> Learning
              </a>
            </div>
          </article>
        <% }) %>
      </div>
    <% } %>

  </div>
</main>

<%- include('../partials/footer') %>
