<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<main id="main-content">
  <div class="container">

    <div class="page-header">
      <div>
        <h1>لوحة تعلّمي</h1>
        <p class="text-muted">مرحباً بعودتك، <strong><%= user.name %></strong>!</p>
      </div>
      <a href="/levels" class="btn btn-primary">استعرض المزيد من المستويات</a>
    </div>

    <%- include('../partials/flash') %>

    <!-- إحصاءات -->
    <div class="stat-cards mb-4" aria-label="إحصاءات التعلم">
      <div class="stat-card">
        <div class="stat-number"><%= enrollments.length %></div>
        <div class="stat-label">المستويات المسجّلة</div>
      </div>
      <div class="stat-card">
        <div class="stat-number"><%= totalCompleted %></div>
        <div class="stat-label">الدروس المكتملة</div>
      </div>
    </div>

    <!-- المستويات المسجّلة -->
    <h2 class="mb-3">مستوياتي</h2>
    <% if (enrollments.length === 0) { %>
      <div class="alert alert-info">
        لم تسجّل في أي مستوى بعد. <a href="/levels">استعرض المستويات</a> للبدء!
      </div>
    <% } else { %>
      <div class="grid grid-2">
        <% enrollments.forEach(enr => { %>
          <article class="course-card">
            <div class="course-card-body">
              <h3><%= enr.course ? enr.course.title : 'المستوى غير متاح' %></h3>
              <p><%= enr.course && enr.course.description ? enr.course.description : '' %></p>

              <!-- شريط التقدم -->
              <% const completed = enr.lessons.filter(l => l.completed).length; %>
              <% const total = enr._totalLessons || 0; %>
              <% const pct = total > 0 ? Math.round((completed / total) * 100) : 0; %>
              <div class="mt-2">
                <div style="display:flex;justify-content:space-between;font-size:.85rem;margin-bottom:.25rem">
                  <span>التقدم</span>
                  <span><%= completed %> / <%= total %> درس</span>
                </div>
                <div class="progress-bar-wrap">
                  <div
                    class="progress-bar-fill <%= pct === 100 ? 'full' : '' %>"
                    style="width:<%= pct %>%"
                    role="progressbar"
                    aria-valuenow="<%= pct %>"
                    aria-valuemin="0"
                    aria-valuemax="100"
                    aria-label="<%= pct %>% مكتمل"
                  ></div>
                </div>
              </div>
            </div>
            <div class="course-card-footer">
              <a href="/levels/<%= enr.course ? enr.course._id : '' %>" class="btn btn-primary btn-sm">
                <%= completed > 0 ? 'متابعة التعلم' : 'بدء التعلم' %>
              </a>
            </div>
          </article>
        <% }) %>
      </div>
    <% } %>

  </div>
</main>

<%- include('../partials/footer') %>
