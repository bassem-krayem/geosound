<nav class="navbar" role="navigation" aria-label="التنقل الرئيسي">
  <div class="container">
    <a class="navbar-brand" href="/" aria-label="الصفحة الرئيسية لجيوساوند">
      🌍 جيوساوند
    </a>
    <ul class="navbar-nav" role="list">
      <% if (typeof user !== 'undefined' && user) { %>
        <% if (user.role === 'student') { %>
          <li><a href="/courses" class="<%= typeof activePage !== 'undefined' && activePage === 'courses' ? 'active' : '' %>">الدورات</a></li>
          <li><a href="/dashboard" class="<%= typeof activePage !== 'undefined' && activePage === 'dashboard' ? 'active' : '' %>">تعلّمي</a></li>
        <% } %>
        <% if (user.role === 'teacher') { %>
          <li><a href="/teacher/dashboard" class="<%= typeof activePage !== 'undefined' && activePage === 'dashboard' ? 'active' : '' %>">لوحة التحكم</a></li>
          <li><a href="/teacher/courses" class="<%= typeof activePage !== 'undefined' && activePage === 'my-courses' ? 'active' : '' %>">دوراتي</a></li>
        <% } %>
        <li>
          <form action="/logout" method="POST" style="margin:0">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <button type="submit" class="btn btn-sm btn-nav" aria-label="تسجيل الخروج من جيوساوند">تسجيل الخروج</button>
          </form>
        </li>
        <li><span class="tag <%= user.role === 'teacher' ? 'tag-teacher' : 'tag-student' %>"><%= user.name %></span></li>
      <% } else { %>
        <li><a href="/courses">الدورات</a></li>
        <li><a href="/login">تسجيل الدخول</a></li>
        <li><a href="/register" class="btn btn-sm btn-nav">إنشاء حساب</a></li>
      <% } %>
    </ul>
  </div>
</nav>
